def compute_distance_map(pattern: np.ndarray):
    """
    Compute the distance map for the given pattern. The values of the map are computed as 
    the distance to the closest pattern contour.

    Args
    ----
    pattern: np.ndarray (28, 28)
        Pattern to process

    Return
    ------
    distance_map: np.ndarray (28, 28)
        Distance map where each entry is the distance to the closest pattern contour (shortest 
        distance to pattern)
    """
    
    # Initialize dummy values
    distance_map = np.zeros_like(pattern)
    
    # ------------------
    # Your code here ... 
    # ------------------
    h, w = distance_map.shape
    found_contours = find_contours(pattern, level=0.5)
    if len(found_contours) > 0:
        pattern_contour = max(found_contours, key=len)
    pattern_contour = np.rint(pattern_contour).astype(int)
    pattern_contour[:, 0] = np.clip(pattern_contour[:, 0], 0, h-1) 
    pattern_contour[:, 1] = np.clip(pattern_contour[:, 1], 0, w-1) 
    
    distance_map = np.full(pattern.shape, np.inf, dtype=float)
    distance_map[pattern_contour[:, 0], pattern_contour[:, 1]] = 0

    # chamfer distance
    for i in range(h):
        for j in range(w):
            if i> 0:
                distance_map[i, j] = min(distance_map[i, j], distance_map[i-1, j] + 3)
            if j > 0:
                distance_map[i, j] = min(distance_map[i, j], distance_map[i, j-1] + 3)
            if i > 0 and j > 0:
                distance_map[i, j] = min(distance_map[i, j], distance_map[i-1, j-1] + 4)
            if i > 0 and j < w-1:
                distance_map[i, j] = min(distance_map[i, j], distance_map[i-1, j+1] + 4)
    
    for i in range(h-1, -1, -1):
        for j in range(w-1, -1, -1):
            if i < h-1:
                distance_map[i, j] = min(distance_map[i, j], distance_map[i+1, j] + 3)
            if j < w-1:
                distance_map[i, j] = min(distance_map[i, j], distance_map[i, j+1] + 3)
            if i < h-1 and j < w-1:
                distance_map[i, j] = min(distance_map[i, j], distance_map[i+1, j+1] + 4)
            if i < h-1 and j > 0:
                distance_map[i, j] = min(distance_map[i, j], distance_map[i+1, j-1] + 4)

    return distance_map


