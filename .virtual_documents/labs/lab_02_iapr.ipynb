def apply_rotation(img: np.ndarray):
    """
    Apply random rotation to input the image
    
    Args
    ----
    image: np.ndarray (28, 28)
        Source images
        
    Return
    ------
    rotated: np.ndarray (28, 28)
        Rotated source images
    """

    rotated = np.zeros_like(img)
    
    # ------------------
    # Your code here ... 
    # ------------------
    angle = np.random.uniform(-40, 40)
    rotated = rotate(
        img,
        angle,
        resize=False,
        preserve_range=True,
        order=0,           
        mode='constant',
        cval=0
    )
    return rotated.astype(img.dtype)

def apply_scaling(img: np.ndarray):
    """
    Apply random scaling to input image
    
    Args
    ----
    image: np.ndarray (28, 28)
        Source images
        
    Return
    ------
    scaled: np.ndarray (28, 28)
        Scaled source images
    """
    
    scaled = np.zeros_like(img)
    
    # ------------------
    # Your code here ... 
    # ------------------
    factor = np.random.uniform(0.4, 1.3)

    h, w = img.shape
    new_h = max(1, int(round(h * factor)))
    new_w = max(1, int(round(w * factor)))

    scaled_tmp = resize(img, (new_h, new_w),
        order=0,         
        preserve_range=True,
        anti_aliasing=False,
        mode='constant',
        cval=0
    )

    scaled = np.zeros_like(img)

    if new_h >= h and new_w >= w:
        y0 = (new_h - h) // 2
        x0 = (new_w - w) // 2
        scaled = scaled_tmp[y0:y0+h, x0:x0+w]
    else:
        y0 = (h - new_h) // 2
        x0 = (w - new_w) // 2
        scaled[y0:y0+new_h, x0:x0+new_w] = scaled_tmp

    return scaled.astype(img.dtype)

def apply_translate(img: np.ndarray):
    """
    Apply random x and y translation to input image
    
    Args
    ----
    image: np.ndarray (28, 28)
        Source images
        
    Return
    ------
    translated: np.ndarray (28, 28)
        Translated source images
    """
    translated = np.zeros_like(img)
    
    # ------------------
    # Your code here ... 
    # ------------------
    tx = np.random.randint(-2, 2)  
    ty = np.random.randint(-2, 2)  

    translated = np.zeros_like(img)

    h, w = img.shape

    src_x0 = max(0, -tx)
    src_x1 = min(w, w - tx)
    src_y0 = max(0, -ty)
    src_y1 = min(h, h - ty)

    dst_x0 = max(0, tx)
    dst_x1 = min(w, w + tx)
    dst_y0 = max(0, ty)
    dst_y1 = min(h, h + ty)

    translated[dst_y0:dst_y1, dst_x0:dst_x1] = img[src_y0:src_y1, src_x0:src_x1]
    return translated.astype(img.dtype)



